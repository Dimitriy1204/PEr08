# Конфигурация для RAG-ассистента (Yandex Embeddings + GigaChat)
# Консолидированная версия — единый ассистент с корневой папкой /DATA

# === Яндекс Эмбеддинги ===

# API ключ Яндекс для доступа к Yandex Foundation Models (обязательно!)
YANDEX_API_KEY=

# Folder ID Яндекс Облака (обязательно!)
YANDEX_FOLDER_ID=

# Модель эмбеддингов
EMBEDDING_MODEL=emb://<YANDEX_FOLDER_ID>/text-embeddings/latest

# === GigaChat (LLM для ответов) ===

# Учётные данные GigaChat (обязательно!)
GIGACHAT_CREDENTIALS=

# Модель GigaChat
GIGACHAT_MODEL=GigaChat-2

# Температура генерации
GIGACHAT_TEMPERATURE=0.15

# === Настройки векторной базы ===

# Директория для ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Размер чанка в символах (по умолчанию 300)
CHUNK_SIZE=300

# Перекрытие между чанками в символах (по умолчанию 50)
CHUNK_OVERLAP=50

# Количество документов для поиска (top_k)
TOP_K=3

# === Настройки кеша ===

CACHE_FILE=cache.json

# === Источники данных ===

DATA_DIR=DATA
